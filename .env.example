# rag-search embedding config. Copy to `.env` (gitignored) and fill in for live use.
# The offline default (EMBED_PROVIDER=mock) needs none of these set.

# "mock" = offline deterministic embedder (default); "api" = live OpenAI-compatible endpoint
EMBED_PROVIDER=mock

# --- live settings (only used when EMBED_PROVIDER=api) ---
# Example: OpenAI text-embedding-3-large at 1024 dims (Matryoshka — near-lossless vs native 3072).
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=
EMBED_MODEL=text-embedding-3-large
EMBED_DIM=1024

# Send EMBED_DIM as the API `dimensions` param (Matryoshka shortening). true for OpenAI v3 models.
# Set false for providers that don't support it (e.g. SiliconFlow bge-m3) — then EMBED_DIM must
# equal the model's native dimension.
EMBED_SEND_DIMENSIONS=true

# --- search ---
# How many part-level hits search returns (presentation groups them by note). Tune here, no code change.
SEARCH_TOP_K=5
# Agentic retrieval: max search rounds before the agent must stop and report. User-tunable, no code change.
SEARCH_MAX_ROUNDS=3
